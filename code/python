# 9. Сравнение с ΛCDM
# ============================================

print("\n" + "="*70)
print("СРАВНЕНИЕ С ΛCDM")
print("="*70)

class LCDM:
    def __init__(self, H0=70, Om=0.315):
        self.H0 = H0
        self.Om = Om
    def H_z(self, z):
        return self.H0 * np.sqrt(self.Om*(1+z)**3 + (1-self.Om))

def lcdm_chi2(params):
    H0, Om = params
    if not (50 < H0 < 80 and 0.2 < Om < 0.4):
        return 1e10
    model = LCDM(H0, Om)
    chi2 = ((H0 - shoes_H0)/shoes_err)**2
    for _, row in bao_df.iterrows():
        chi2 += ((row['Hrs_obs'] - model.H_z(row['z'])*147.09/100) / row['Hrs_err'])**2
    for i in range(len(z_sne)):
        mu_model = 5 * np.log10((1+z_sne[i]) * z_sne[i] * 4300 * 1e5)
        chi2 += ((mu_obs[i] - mu_model) / mu_err[i])**2
    return chi2

res_lcdm = minimize(lcdm_chi2, [70, 0.315])
chi2_lcdm = res_lcdm.fun

# χ² Хроносферы
best_model = ChronosphereModel(*best)
chi2_chrono = 0
chi2_chrono += ((best[0] - shoes_H0)/shoes_err)**2
for _, row in bao_df.iterrows():
    chi2_chrono += ((row['Hrs_obs'] - best_model.H_z(row['z'])*147.09/100) / row['Hrs_err'])**2
for i in range(len(z_sne)):
    mu_model = best_model.D_L(z_sne[i])
    chi2_chrono += ((mu_obs[i] - mu_model) / mu_err[i])**2
for _, row in kinematic_df.iterrows():
    chi2_chrono += ((row['v_obs'] - best_model.radial_flow(row['r_mpc'])) / row['v_err'])**2

print(f"ΛCDM: χ² = {chi2_lcdm:.2f}")
print(f"Хроносфера: χ² = {chi2_chrono:.2f}")
print(f"Разница: Δχ² = {chi2_lcdm - chi2_chrono:.2f} в пользу Хроносферы")

# AIC
delta_AIC = (chi2_chrono + 2*9) - (chi2_lcdm + 2*2)
print(f"ΔAIC = {delta_AIC:.2f}")
if delta_AIC < -2:
    print("✓ Хроносфера предпочтительнее ΛCDM")
else:
    print("Модели сравнимы")

print("\nАнализ завершен.")
