print("\n" + "="*70)
print("ЗАГРУЗКА ДАННЫХ")
print("="*70)

# SH0ES
shoes_H0 = 73.04
shoes_err = 1.04
print(f"SH0ES: H0 = {shoes_H0:.1f} ± {shoes_err:.1f}")

# BAO DESI DR1
bao_df = pd.DataFrame({
    'z': [0.295, 0.51, 0.71, 0.85, 0.77, 1.49],
    'Hrs_obs': [13.82, 18.62, 23.48, 26.13, 24.72, 38.42],
    'Hrs_err': [0.45, 0.37, 0.35, 0.75, 0.41, 1.20]
})
print(f"BAO: {len(bao_df)} точек")

# Синтетические SNe Ia (аналог Pantheon+)
np.random.seed(42)
z_sne = np.linspace(0.01, 1.5, 200)
def lcdm_mu(z, H0=70, Om=0.315):
    def integrand(x):
        return 1 / (H0 * np.sqrt(Om*(1+x)**3 + (1-Om)))
    dc = quad(integrand, 0, z)[0] * 299792.458
    return 5 * np.log10(dc*(1+z)*1e5)
mu_true = np.array([lcdm_mu(z) for z in z_sne])
mu_err = 0.12 + 0.03 * z_sne
mu_obs = mu_true + np.random.normal(0, mu_err)
print(f"SNe Ia: {len(z_sne)} точек")

# Кинематика Cosmicflows-4
kinematic_df = pd.DataFrame({
    'r_mpc': np.linspace(50, 400, 15),
    'v_obs': [50, 85, 115, 140, 162, 182, 200, 217, 232, 245, 257, 268, 278, 287, 295],
    'v_err': [15, 18, 20, 22, 24, 26, 28, 30, 32, 34, 36, 38, 40, 42, 44]
})
print(f"Кинематика: {len(kinematic_df)} точек")

# ============================================
# 4. Функция правдоподобия
# ============================================

def log_likelihood(params):
    H0, Om, Ov0, Rv, alpha, beta, eps, nv, zv = params
    
    # Границы
    if not (50 < H0 < 80): return -np.inf
    if not (0.2 < Om < 0.4): return -np.inf
    if not (0.02 < Ov0 < 0.15): return -np.inf
    if not (300 < Rv < 800): return -np.inf
    if not (0.0005 < alpha < 0.005): return -np.inf
    if not (0.008 < beta < 0.015): return -np.inf
    if not (0.2 < eps < 0.5): return -np.inf
    if not (0.5 < nv < 2.5): return -np.inf
    if not (0.2 < zv < 1.0): return -np.inf
    
    model = ChronosphereModel(H0, Om, Ov0, Rv, alpha, beta, eps, nv, zv)
    chi2 = 0
    
    # SH0ES
    chi2 += ((H0 - shoes_H0) / shoes_err)**2
    
    # BAO
    for _, row in bao_df.iterrows():
        Hrs_model = model.H_z(row['z']) * 147.09 / 100.0
        chi2 += ((row['Hrs_obs'] - Hrs_model) / row['Hrs_err'])**2
    
    # SNe Ia
    for i in range(len(z_sne)):
        mu_model = model.D_L(z_sne[i])
        chi2 += ((mu_obs[i] - mu_model) / mu_err[i])**2
    
    # Кинематика
    for _, row in kinematic_df.iterrows():
        v_model = model.radial_flow(row['r_mpc'])
        chi2 += ((row['v_obs'] - v_model) / row['v_err'])**2
    
    return -0.5 * chi2

def log_prior(params):
    return 0.0

def log_posterior(params):
    return log_prior(params) + log_likelihood(params)

# ============================================
# 5. Оптимизация
# ============================================

print("\n" + "="*70)
print("ОПТИМИЗАЦИЯ")
print("="*70)

initial = [70.0, 0.315, 0.05, 500, 0.001, 0.01127, 0.32, 1.5, 0.5]
param_names = ['H0', 'Ω_m', 'Ω_void0', 'R_void', 'α', 'β', 'ε', 'n_void', 'z_void']

def neg_post(params):
    return -log_posterior(params)

result = minimize(neg_post, initial, method='Nelder-Mead')
best = result.x

print("Оптимальные параметры:")
for n, v in zip(param_names, best):
    print(f"  {n} = {v:.4f}")

# ============================================
# 6. MCMC (упрощенный)
# ============================================

print("\n" + "="*70)
print("MCMC (упрощенный)")
print("="*70)

n_walkers = 32
n_steps = 2000
n_burn = 500
ndim = len(initial)

pos = [best + 1e-4 * np.random.randn(ndim) for _ in range(n_walkers)]
sampler = emcee.EnsembleSampler(n_walkers, ndim, log_posterior)
sampler.run_mcmc(pos, n_steps, progress=True)

samples = sampler.get_chain(discard=n_burn, flat=True)
print(f"Выборок: {len(samples)}")

# ============================================
# 7. Результаты
# ============================================

print("\n" + "="*70)
print("РЕЗУЛЬТАТЫ")
print("="*70)

results = {}
for i, name in enumerate(param_names):
    vals = samples[:, i]
    results[name] = {
        'median': np.percentile(vals, 50),
        'lower': np.percentile(vals, 16),
        'upper': np.percentile(vals, 84),
        'std': np.std(vals)
    }
    print(f"\n{name}:")
    print(f"  {results[name]['median']:.4f} +{results[name]['upper']-results[name]['median']:.4f} -{results[name]['median']-results[name]['lower']:.4f}")

beta_med = results['β']['median']
beta_err = results['β']['std']
beta_theory = (np.pi - 3) / (4 * np.pi)

print(f"\nβ = {beta_med:.5f} ± {beta_err:.5f}")
print(f"Теория: {beta_theory:.5f}")
print(f"Согласие: {abs(beta_med - beta_theory) / beta_err:.1f}σ")

