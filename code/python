# 2. Модель Хроносферы
# ============================================

class ChronosphereModel:
    def __init__(self, H0=70, Omega_m=0.315, Omega_void0=0.05, R_void=500,
                 alpha=0.001, beta=0.01127, epsilon=0.32, n_void=1.5, z_void=0.5):
        self.H0 = H0
        self.Omega_m = Omega_m
        self.Omega_void0 = Omega_void0
        self.R_void = R_void
        self.Omega_Lambda0 = 1 - Omega_m - Omega_void0
        self.alpha = alpha
        self.beta = beta
        self.epsilon = epsilon
        self.n_void = n_void
        self.z_void = z_void
        
    def Omega_void(self, z):
        return self.Omega_void0 * (1+z)**self.n_void * np.exp(-(z/self.z_void)**2)
    
    def H_z(self, z):
        Omega_total = self.Omega_m * (1+z)**3 + self.Omega_void(z) + self.Omega_Lambda0
        return self.H0 * np.sqrt(max(Omega_total, 0.01))
    
    def D_L(self, z):
        def integrand(zp):
            return 1 / self.H_z(zp)
        dc = quad(integrand, 0, z)[0] * 299792.458
        return 5 * np.log10(dc * (1+z) * 1e5)
    
    def radial_flow(self, r):
        return self.alpha * self.H0 * r * (1 - np.exp(-r / self.R_void))
    
    def kinematic_dipole(self, z):
        return self.radial_flow(z * 4300) / 299792.458

